rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPER FUNCTIONS ---
    
    // Checks if the user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Fetches admin record from Firestore (admins collection)
    function getAdminData() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid)).data;
    }

    // Checks for specific admin roles
    function hasAdminRole(role) {
      return isSignedIn() && getAdminData().role == role;
    }

    function isAdmin() {
      return hasAdminRole('admin') || hasAdminRole('super_admin');
    }

    function isSuperAdmin() {
      return hasAdminRole('super_admin');
    }

    // Checks if the user is the owner of the document
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    // 1. Users Collection
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow delete: if isSuperAdmin();
    }

    // 2. Orders Collection
    match /orders/{orderId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); 
      allow update: if isSignedIn();
      allow delete: if isSuperAdmin();
    }

    // 3. Stores Collection
    match /stores/{storeId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin(); 
      allow delete: if isSuperAdmin();
    }

    // 4. Colleges Collection
    match /colleges/{collegeId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // 5. Vendors Collection
    match /vendors/{vendorId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null || isAdmin();

      // 5a. Foods Subcollection (vendor menu items)
      match /foods/{foodId} {
        allow read: if true;  // Public menu
        allow create, update, delete: if request.auth.uid == vendorId || isAdmin();
      }
    }

    // 6. Admins Collection
    match /admins/{adminId} {
      allow read: if isSignedIn() && (isOwner(adminId) || isAdmin());
      allow write: if isSuperAdmin();
    }

    // 7. Service Configs (Highly Sensitive)
    match /service_configs/{configId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // 8. Admin Stats (Internal aggregation)
    match /admin_stats/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // 9. Payments Collection
    match /payments/{paymentId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // 10. Sessions Collection
    match /sessions/{sessionId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // 11. Notifications Collection
    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
